{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lp-wizard",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "main": "src/worker.js",
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "vars": {
    "LP_WIZARD_USER": "kuribou202"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
